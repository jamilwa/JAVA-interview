           public static boolean isPalindrome(String word) {
              int left = 0;
              int right = word.length() - 1;
      
              while (left < right) {
                  if (word.charAt(left++) != word.charAt(right--)) {
                      return false;
                  }
              }
      
              return true;
          }
      

5. Parentheses balanced

      public static boolean isBalanced(String s) {
        Deque<Character> stack = new ArrayDeque<>();
        for (char c : s.toCharArray()) {                  
            if (c == '(' || c == '[' || c == '{') {
                stack.push(c);
            } 
            else if (c == ')' || c == ']' || c == '}') {
                 if (stack.isEmpty()){
                    return false;
                }
                char open = stack.pop();
                if ((open == '(' && c != ')') || (open == '[' && c != ']') || (open == '{' && c != '}')) {
                    return false;
                }
            } 
            else {
                return false;
            }
        }
        return stack.isEmpty();   // true only if no unmatched openings remain
    }

