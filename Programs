    }


15. reverseArray
    static void reverseArray(int a[]) {
        System.out.println("Array Before Reverse : " + Arrays.toString(a));
        // int a[] = {1,3,6,0,2,0,0,4,3,}
        int i = 0, j = a.length - 1;
        while (i < j) {
            int tmp = a[i];
            a[i] = a[j];
            a[j] = tmp;
            i++;
            j--;
        }

        System.out.println("Array After Reverse : " + Arrays.toString(a));
    }


