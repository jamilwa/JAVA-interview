17. Java program which prints all contiguous sub arrays with given sum
    private static void hashingMethod(int[] arr, int target) {

        int prefixSum = 0;

        // prefixSum → list of indices where this sum occurred
        Map<Integer, List<Integer>> map = new HashMap<>();
        map.computeIfAbsent(0, x -> new ArrayList<>()).add(-1);

        for (int i = 0; i < arr.length; i++) {
            prefixSum += arr[i];
            int needed = prefixSum - target;

            if (map.containsKey(needed)) {
                for (int start : map.get(needed)) {
                    print(arr, start + 1, i);
                }
            }

            map.computeIfAbsent(prefixSum, x -> new ArrayList<>()).add(i);
        }
    }

    private static void print(int[] arr, int start, int end) {
        System.out.print("[ ");
        for (int i = start; i <= end; i++) {
            System.out.print(arr[i] + " ");
        }
        System.out.println("]");
    }


