        // int a[] = {1,3,6,0,2,0,0,4,3,}                           // to move zeroes to front  do below changes in comment
        int c = 0;                                                  //   a.length - 1
        for (int i = 0; i < a.length; i++) {                         //  int i=a.length - 1;i>=0;i--
            if (a[i] != 0) {
                a[c++] = a[i];                                      // a[c--]
